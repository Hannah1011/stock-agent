ANTHROPIC_API_KEY=your_anthropic_api_key_here
NEWS_API_KEY=your_newsapi_key_here

# 임베딩 모델 선택
# "local"  : snunlp/KR-SBERT (기본값, 무료, 첫 실행 시 ~400MB 다운로드)
# "openai" : text-embedding-3-small (유료, 빠른 시작, OPENAI_API_KEY 필요)
EMBEDDING_PROVIDER=local

# EMBEDDING_PROVIDER=openai를 선택할 때만 필요
OPENAI_API_KEY=your_openai_api_key_here

# 선택 사항: 다른 위치의 포트폴리오 파일을 사용할 때만 설정
# PORTFOLIO_PATH=/absolute/path/to/portfolio.json

# 종목 목록 공급자
# "local": 키워드 맵 + portfolio.json + Yahoo Finance 사용 (기본값)
# "pykrx": KRX 조회를 먼저 시도하고 실패 시 local 방식으로 전환
STOCK_CATALOG_PROVIDER=local
